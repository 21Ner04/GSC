# --- Content source ---
# local (default) = JSON files in /content
# wordpress = headless WP REST API (plugin: wordpress-plugin/gsc-cms)
CONTENT_SOURCE=local

# WordPress REST root (include /wp-json)
# WORDPRESS_API_URL=https://cms.yourdomain.com/wp-json
# WORDPRESS_REVALIDATE_SECONDS=60
# Shared secret for POST /api/revalidate from WP
# WORDPRESS_REVALIDATE_SECRET=change-me-to-a-long-random-string

# Optional UserWay accessibility account
# NEXT_PUBLIC_USERWAY_ACCOUNT_ID=

# Optional brand overrides
# NEXT_PUBLIC_NAVBAR_LOGO_SRC=/images/logo.png
# NEXT_PUBLIC_BRAND_NAME=Green Street Capital
