# --- Content source ---
# local (default) = JSON files in /content
# wordpress = headless WP REST API (plugin: wordpress-plugin/gsc-cms)
CONTENT_SOURCE=local

# WordPress REST root (include /wp-json)
# WORDPRESS_API_URL=https://cms.greenstreetcapitalgroup.com/wp-json
# WORDPRESS_REVALIDATE_SECONDS=60
# Shared secret for POST /api/revalidate from WP (must match GSC Site Settings)
# WORDPRESS_REVALIDATE_SECRET=change-me-to-a-long-random-string
# Next.js revalidate URL for WP settings: https://www.greenstreetcapitalgroup.com/api/revalidate

# Google Search Console HTML tag verification (optional)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# --- Live Google Reviews (homepage) ---
# Enable Places API (Place Details + Find Place) on Google Cloud, then:
# GOOGLE_PLACES_API_KEY=your-api-key
# Optional: pin exact listing (from Place ID Finder). If omitted, auto-finds by name/address.
# GOOGLE_PLACE_ID=ChIJ...
# Optional override for find-place query:
# GOOGLE_PLACE_QUERY=Green Street Capital, LLC 2709 Coney Island Ave Brooklyn NY

# Optional UserWay accessibility account
# NEXT_PUBLIC_USERWAY_ACCOUNT_ID=

# Optional brand overrides
# NEXT_PUBLIC_NAVBAR_LOGO_SRC=/images/logo.png
# NEXT_PUBLIC_NAVBAR_LOGO_ALT=Green Street Capital
# NEXT_PUBLIC_BRAND_NAME=Green Street Capital
# NEXT_PUBLIC_TEAM_HREF=/team
# NEXT_PUBLIC_APPLY_HREF=/apply
